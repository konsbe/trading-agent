# Copy to .env at the repository root.
# Local runs: workers read .env via godotenv (cwd = where you start the binary).
# Docker: compose injects variables from this file; DATABASE_URL is overridden for DB hostname "timescaledb".

# --- Shared ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trading?sslmode=disable
LOG_LEVEL=info

# Default poll interval when a per-source *_POLL_INTERVAL below is omitted (Go duration: 30s, 5m, 1h, …).
DATA_POLL_INTERVAL=60s

# Per-source intervals (each falls back to DATA_POLL_INTERVAL if unset or invalid).
DATA_CRYPTO_BINANCE_REST_POLL_INTERVAL=
DATA_CRYPTO_COINGECKO_POLL_INTERVAL=

DATA_EQUITY_ALPACA_POLL_INTERVAL=
DATA_EQUITY_FINNHUB_POLL_INTERVAL=
DATA_EQUITY_FRED_POLL_INTERVAL=

DATA_ONCHAIN_GLASSNODE_POLL_INTERVAL=
DATA_ONCHAIN_ETHERSCAN_POLL_INTERVAL=

DATA_SENTIMENT_LUNARCRUSH_POLL_INTERVAL=
DATA_SENTIMENT_FINNHUB_NEWS_POLL_INTERVAL=

# --- data-crypto ---
# Binance: public kline REST + optional WS use no API key (keys are only for private/trading endpoints).
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT
# Kline size for Binance REST/WS (e.g. 1m, 1h), not the poll interval.
BINANCE_INTERVAL=1h
COINGECKO_POLL_GLOBAL=true
# Optional live klines (separate from REST polling).
BINANCE_ENABLE_WS=false

# --- data-equity (paper trading: set APCA_API_BASE_URL=https://paper-api.alpaca.markets) ---
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_API_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_SYMBOLS=AAPL,MSFT,SPY
FRED_API_KEY=
FRED_SERIES_IDS=DGS10,DEXUSEU,VIXCLS
FINNHUB_API_KEY=
# If Finnhub (or other HTTPS) fails with x509 unknown authority in Docker—often TLS inspection on
# corporate/VPN networks—export your proxy root as PEM and mount it in compose, then set the path
# inside the container, e.g. EXTRA_ROOT_CA_FILE=/etc/ssl/extra/corp-root.pem
EXTRA_ROOT_CA_FILE=

# --- data-onchain ---
GLASSNODE_API_KEY=
ETHERSCAN_API_KEY=

# --- data-sentiment (LunarCrush uses FINNHUB_SYMBOLS_FOR_NEWS list for coin symbols) ---
LUNARCRUSH_API_KEY=
FINNHUB_SYMBOLS_FOR_NEWS=BTC,ETH,AAPL

# --- data-technical ---
# Symbols to analyse (defaults to ALPACA_DATA_SYMBOLS / BINANCE_SYMBOLS if unset).
TECHNICAL_EQUITY_SYMBOLS=AAPL,MSFT,SPY
TECHNICAL_CRYPTO_SYMBOLS=BTCUSDT,ETHUSDT

# Bar timeframes to ingest and compute (comma-separated).
# Equity uses Alpaca format: 1Min, 5Min, 15Min, 1Hour, 1Day, 1Week, 1Month
# Crypto uses Binance format: 1m, 5m, 15m, 1h, 4h, 1d, 1w
TECHNICAL_EQUITY_INTERVALS=1Day
TECHNICAL_CRYPTO_INTERVALS=1d

# How many historical bars to ensure are stored on startup (backfill target).
# 500 daily bars ≈ 2 years of history, sufficient for 200-period SMA/EMA.
TECHNICAL_BACKFILL_BARS=500

# How many bars to read from the DB for each computation run.
TECHNICAL_COMPUTE_LOOKBACK=500

# How often to fetch the latest bars and recompute all indicators (Go duration).
DATA_TECHNICAL_POLL_INTERVAL=6h

# Moving average periods (comma-separated integers).
TECHNICAL_SMA_PERIODS=20,50,100,200
TECHNICAL_EMA_PERIODS=9,21,50,200

# RSI period.
TECHNICAL_RSI_PERIOD=14

# Volume SMA period (used for vol_sma_N and rel_vol indicators).
TECHNICAL_VOL_SMA_PERIOD=20

# Support & Resistance: bars on each side to qualify a swing point.
TECHNICAL_SR_SWING_STRENGTH=5
# Max support and resistance levels to store.
TECHNICAL_SR_LEVELS=3
# Price proximity tolerance (%) for clustering nearby levels into one.
TECHNICAL_SR_CLUSTER_PCT=0.5

# Trend analysis: bars used for slope and HH/HL structure check.
TECHNICAL_TREND_LOOKBACK=60

# Feature toggles (set to false to disable a group entirely).
TECHNICAL_ENABLE_MA=true
TECHNICAL_ENABLE_RSI=true
TECHNICAL_ENABLE_VOLUME=true
TECHNICAL_ENABLE_SR=true
TECHNICAL_ENABLE_TREND=true
TECHNICAL_ENABLE_CANDLES=true

# Tier 2 — momentum, volatility, structure (each row in technical_indicators is per symbol × interval).
TECHNICAL_ENABLE_MACD=true
TECHNICAL_MACD_FAST=12
TECHNICAL_MACD_SLOW=26
TECHNICAL_MACD_SIGNAL=9

TECHNICAL_ENABLE_OBV=true

TECHNICAL_ENABLE_BOLLINGER=true
TECHNICAL_BB_PERIOD=20
TECHNICAL_BB_STD=2

TECHNICAL_ENABLE_FIB=true
# 0 = reuse TECHNICAL_SR_SWING_STRENGTH for Fib pivots.
TECHNICAL_FIB_SWING_STRENGTH=0
TECHNICAL_FIB_EXTENSIONS=true

TECHNICAL_ENABLE_RSI_DIVERGENCE=true
# 0 = reuse TECHNICAL_SR_SWING_STRENGTH for RSI swing pivots.
TECHNICAL_RSI_DIV_SWING_STRENGTH=0

# Histogram proxy: each bar's volume → one price bin (typical price or close); not tape/L2.
TECHNICAL_ENABLE_VOL_PROFILE_PROXY=true
TECHNICAL_VOL_PROFILE_BINS=48
TECHNICAL_VOL_PROFILE_TYPICAL=true
# Value area: expand bins from POC until this fraction of histogram volume is captured (e.g. 0.70 = 70%).
TECHNICAL_VOL_PROFILE_VALUE_AREA_PCT=0.70

# RSI hidden (continuation) divergence: min bars between the two pivots; optional trend gate (AnalyzeTrend on window ending at 2nd pivot).
TECHNICAL_ENABLE_RSI_HIDDEN=true
TECHNICAL_RSI_HIDDEN_MIN_PIVOT_SEP=3
TECHNICAL_RSI_HIDDEN_REQUIRE_TREND=true

# Tier 3 — secondary indicators (same DB grain: per symbol × interval).
TECHNICAL_ENABLE_STOCHASTIC=true
TECHNICAL_STOCH_K=14
TECHNICAL_STOCH_D_SMOOTH=3
TECHNICAL_STOCH_D_SIGNAL=3

TECHNICAL_ENABLE_ATR=true
TECHNICAL_ATR_PERIOD=14

TECHNICAL_ENABLE_ICHIMOKU=true
TECHNICAL_ICHIMOKU_TENKAN=9
TECHNICAL_ICHIMOKU_KIJUN=26
TECHNICAL_ICHIMOKU_SPAN_B=52
# 0 = use Kijun length as Senkou displacement (standard 26).
TECHNICAL_ICHIMOKU_DISPLACE=0

TECHNICAL_ENABLE_AD_LINE=true

TECHNICAL_ENABLE_ADX=true
TECHNICAL_ADX_PERIOD=14

# Classic / Camarilla / Woodie from prior bar H/L/C (bars[len-2]).
TECHNICAL_ENABLE_PIVOTS=true

TECHNICAL_ENABLE_WILLIAMS_R=true
TECHNICAL_WILLIAMS_R_PERIOD=14

# VWAP: rolling window over last N bars, or session = all bars on last bar's UTC calendar day (useful on intraday bars).
TECHNICAL_ENABLE_VWAP=true
TECHNICAL_VWAP_MODE=rolling
TECHNICAL_VWAP_ROLLING_N=20
TECHNICAL_VWAP_USE_TYPICAL=true

# MA ribbon: periods ascending short→long; golden/death cross on SMA pair (default 50/200).
TECHNICAL_ENABLE_MA_RIBBON=true
TECHNICAL_RIBBON_PERIODS=10,20,50,200
TECHNICAL_MA_CROSS_FAST=50
TECHNICAL_MA_CROSS_SLOW=200

# Heuristic double top/bottom candidates from last two swings (not full pattern recognition).
TECHNICAL_ENABLE_CHART_PATTERNS=true
TECHNICAL_CHART_PATTERN_CLUSTER_PCT=0.5

# --- Channels / flow / oscillators (OHLCV) ---
TECHNICAL_ENABLE_CMF=true
TECHNICAL_CMF_PERIOD=21

TECHNICAL_ENABLE_KELTNER=true
TECHNICAL_KELTNER_EMA=20
TECHNICAL_KELTNER_ATR=10
TECHNICAL_KELTNER_MULT=2

TECHNICAL_ENABLE_DONCHIAN=true
TECHNICAL_DONCHIAN_PERIOD=20

# OLS trendlines through last N swing highs / lows; break vs prior close.
TECHNICAL_ENABLE_TRENDLINE_BREAK=true
TECHNICAL_TRENDLINE_PIVOTS=3

TECHNICAL_ENABLE_CCI=true
TECHNICAL_CCI_PERIOD=20

TECHNICAL_ENABLE_ROC=true
TECHNICAL_ROC_PERIOD=12

TECHNICAL_ENABLE_PARABOLIC_SAR=true
TECHNICAL_PARABOLIC_STEP=0.02
TECHNICAL_PARABOLIC_MAX_AF=0.2

TECHNICAL_ENABLE_MFI=true
TECHNICAL_MFI_PERIOD=14

# --- Structure / discretionary context ---
TECHNICAL_ENABLE_MARKET_STRUCTURE=true
TECHNICAL_ENABLE_ELLIOTT_HINT=true
TECHNICAL_ENABLE_GANN_HINT=true
TECHNICAL_GANN_LOOKBACK=60

# Documents that OI is not in OHLCV (stores payload only when true).
TECHNICAL_ENABLE_OPEN_INTEREST_INFO=false

# Relative strength vs a second symbol in DB (same interval; timestamp-aligned closes).
TECHNICAL_ENABLE_RS_BENCHMARK=false
TECHNICAL_RS_BENCHMARK_EQUITY=SPY
TECHNICAL_RS_BENCHMARK_CRYPTO=BTCUSDT
TECHNICAL_RS_MIN_ALIGNED_BARS=30

# Multi-timeframe trend confluence: compare primary interval trend to these secondary intervals (same symbol).
TECHNICAL_ENABLE_MTF_CONFLUENCE=false
TECHNICAL_MTF_EQUITY_INTERVALS=1Week
TECHNICAL_MTF_CRYPTO_INTERVALS=1w
