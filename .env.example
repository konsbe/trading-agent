# ── Macro Analysis — Global & Geopolitical (FRED: DTWEXBGS, DEXJPUS, CHNGDPNQDSMEI, FYFSD, GDP) ──
# Broad USD index (DTWEXBGS) — not ICE DXY; same macro interpretation.
GLOBAL_DOLLAR_SUPPORTIVE_MAX=95
GLOBAL_DOLLAR_NEUTRAL_MAX=100
GLOBAL_DOLLAR_HEADWIND_MAX=105
GLOBAL_DOLLAR_STRESS_MIN=110
# USD/JPY carry unwind — % change over ~20 trading sessions (DEXJPUS daily).
GLOBAL_USDJPY_EARLY_UNWIND_PCT=-5.0
GLOBAL_USDJPY_SYSTEMIC_UNWIND_PCT=-10.0
GLOBAL_USDJPY_LOOKBACK_OBS=22
# China GDP YoY % (OECD CHNGDPNQDSMEI, quarterly).
GLOBAL_CHINA_GDP_CONTRACT=3.0
GLOBAL_CHINA_GDP_STABLE=5.0
GLOBAL_CHINA_GDP_EXPANSION=6.0
# Federal deficit as % of nominal GDP (FYFSD millions / GDP billions SAAR).
GLOBAL_FISCAL_MANAGEABLE_PCT=3.0
GLOBAL_FISCAL_ELEVATED_PCT=6.0
# Composite gg_stance boundaries (-1 benign … +1 elevated stress).
GLOBAL_STRESS_ELEVATED_SCORE=0.35
GLOBAL_STRESS_BENIGN_SCORE=-0.15

# ── Bot Startup Report ────────────────────────────────────────────────────────
# Send daily report to the report channel every time the bot starts / restarts.
# Set to false on dev to avoid noise on every reload.
BOT_REPORT_ON_STARTUP=true
BOT_REPORT_ON_STARTUP_DELAY=5
