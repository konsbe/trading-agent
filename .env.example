# Copy to .env at the repository root.
# Local runs: workers read .env via godotenv (cwd = where you start the binary).
# Docker: compose injects variables from this file; DATABASE_URL is overridden for DB hostname "timescaledb".

# --- Shared ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trading?sslmode=disable
LOG_LEVEL=info

# Default poll interval when a per-source *_POLL_INTERVAL below is omitted (Go duration: 30s, 5m, 1h, …).
DATA_POLL_INTERVAL=60s

# Per-source intervals (each falls back to DATA_POLL_INTERVAL if unset or invalid).
DATA_CRYPTO_BINANCE_REST_POLL_INTERVAL=
DATA_CRYPTO_COINGECKO_POLL_INTERVAL=

DATA_EQUITY_ALPACA_POLL_INTERVAL=
DATA_EQUITY_FINNHUB_POLL_INTERVAL=
DATA_EQUITY_FRED_POLL_INTERVAL=

DATA_ONCHAIN_GLASSNODE_POLL_INTERVAL=
DATA_ONCHAIN_ETHERSCAN_POLL_INTERVAL=

DATA_SENTIMENT_LUNARCRUSH_POLL_INTERVAL=
DATA_SENTIMENT_FINNHUB_NEWS_POLL_INTERVAL=

# --- data-crypto ---
# Binance: public kline REST + optional WS use no API key (keys are only for private/trading endpoints).
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT
# Kline size for Binance REST/WS (e.g. 1m, 1h), not the poll interval.
BINANCE_INTERVAL=1h
COINGECKO_POLL_GLOBAL=true
# Optional live klines (separate from REST polling).
BINANCE_ENABLE_WS=false

# --- data-equity (paper trading: set APCA_API_BASE_URL=https://paper-api.alpaca.markets) ---
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_API_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_SYMBOLS=AAPL,MSFT,SPY
FRED_API_KEY=
FRED_SERIES_IDS=DGS10,DEXUSEU,VIXCLS
FINNHUB_API_KEY=

# --- data-onchain ---
GLASSNODE_API_KEY=
ETHERSCAN_API_KEY=

# --- data-sentiment (LunarCrush uses FINNHUB_SYMBOLS_FOR_NEWS list for coin symbols) ---
LUNARCRUSH_API_KEY=
FINNHUB_SYMBOLS_FOR_NEWS=BTC,ETH,AAPL
