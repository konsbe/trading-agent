# Copy to .env at the repository root.
# Local runs: workers read .env via godotenv (cwd = where you start the binary).
# Docker: compose injects variables from this file; DATABASE_URL is overridden for DB hostname "timescaledb".

# --- Shared ---
DATABASE_URL=postgres://postgres:postgres@localhost:5432/trading?sslmode=disable
LOG_LEVEL=info

# Default poll interval when a per-source *_POLL_INTERVAL below is omitted (Go duration: 30s, 5m, 1h, …).
DATA_POLL_INTERVAL=60s

# Per-source intervals (each falls back to DATA_POLL_INTERVAL if unset or invalid).
DATA_CRYPTO_BINANCE_REST_POLL_INTERVAL=
DATA_CRYPTO_COINGECKO_POLL_INTERVAL=

DATA_EQUITY_ALPACA_POLL_INTERVAL=
DATA_EQUITY_FINNHUB_POLL_INTERVAL=
DATA_EQUITY_FRED_POLL_INTERVAL=

DATA_ONCHAIN_GLASSNODE_POLL_INTERVAL=
DATA_ONCHAIN_ETHERSCAN_POLL_INTERVAL=

DATA_SENTIMENT_LUNARCRUSH_POLL_INTERVAL=
DATA_SENTIMENT_FINNHUB_NEWS_POLL_INTERVAL=

# --- data-crypto ---
# Binance: public kline REST + optional WS use no API key (keys are only for private/trading endpoints).
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT
# Kline size for Binance REST/WS (e.g. 1m, 1h), not the poll interval.
BINANCE_INTERVAL=1h
COINGECKO_POLL_GLOBAL=true
# Optional live klines (separate from REST polling).
BINANCE_ENABLE_WS=false

# --- data-equity (paper trading: set APCA_API_BASE_URL=https://paper-api.alpaca.markets) ---
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
APCA_API_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_SYMBOLS=AAPL,MSFT,SPY
FRED_API_KEY=
FRED_SERIES_IDS=DGS10,DEXUSEU,VIXCLS,FEDFUNDS,T10Y2Y,T10Y3M,DFII10,WALCL,BAMLH0A0HYM2,BAMLC0A0CM,T10YIE,T5YIE,DGS2,DGS30,M2SL,USSLIND,ICSA,CCSA,HOUST,PERMIT,GDPC1,PAYEMS,UNRATE,CES0500000003,SAHMREALTIME,RSAFS,RRSFS,UMCSENT,DGORDER,NEWORDER,CPIAUCSL,CPILFESL,CUSR0000SAH1,PCEPI,PCEPILFE,PPIACO,PPIFID,DCOILWTICO,DCOILBRENTEU,ECIALLCIV,PCOPPUSDM,DTWEXBGS,DEXJPUS,CHNGDPNQDSMEI,FYFSD,GDP
FINNHUB_API_KEY=

# --- Corporate / VPN TLS inspection ---
# If any HTTPS endpoint fails with "x509: certificate signed by unknown authority" inside Docker,
# your network is performing TLS inspection and re-signing server certificates with its own CA.
#
# CORP_CA_PEM_PATH   — host-side absolute path to your corporate root CA PEM file.
#                      docker-compose mounts this into the container automatically.
#                      Leave empty (or unset) on machines that do NOT use a corporate proxy.
# EXTRA_ROOT_CA_FILE — container-side path (keep as /etc/ssl/extra/corp-ca.pem).
#                      The Go httpclient merges this into the TLS root pool at startup.
#                      Leave empty if CORP_CA_PEM_PATH is empty.
#
# On a machine with a corporate TLS proxy:
#   CORP_CA_PEM_PATH=/absolute/path/to/trading-agent/infra/corp-ca.pem
#   EXTRA_ROOT_CA_FILE=/etc/ssl/extra/corp-ca.pem
#
# On a personal machine (no corporate proxy):
#   Leave both variables empty — /dev/null is mounted instead, adding no extra certs.
CORP_CA_PEM_PATH=
EXTRA_ROOT_CA_FILE=

# --- data-fundamental ---
# Symbols to pull fundamentals for. Falls back to ALPACA_DATA_SYMBOLS if unset.
# Note: crypto symbols are equity-only; fundamentals are for listed stocks only.
FUNDAMENTAL_SYMBOLS=AAPL,MSFT,SPY

# Alpha Vantage — free API key at https://www.alphavantage.co/support/#api-key
# Provides forward P/E, PEG ratio, beta, sector, analyst target price.
# These are NOT available on Finnhub free tier. Free tier: 25 calls/day.
# With weekly polling and ≤5 symbols this uses only ~5 calls/week.
ALPHA_VANTAGE_API_KEY=

# Poll intervals (Go durations). FA data changes slowly; daily/weekly is sufficient.
# /stock/metric  — key TTM ratios (EPS, revenue, P/E, FCF, margins). Refresh daily.
DATA_FUNDAMENTAL_METRICS_POLL_INTERVAL=24h
# /stock/financials-reported — quarterly income + cash-flow statements. Refresh weekly.
DATA_FUNDAMENTAL_FINANCIALS_POLL_INTERVAL=168h
# /stock/earnings — historical EPS actuals vs estimates. Refresh daily.
DATA_FUNDAMENTAL_EARNINGS_POLL_INTERVAL=24h
# Alpha Vantage OVERVIEW — weekly is plenty; free tier is 25 calls/day.
DATA_FUNDAMENTAL_OVERVIEW_POLL_INTERVAL=168h

# Frequency for the primary financials-reported endpoint: "quarterly" (default) or "annual".
FUNDAMENTAL_FINANCIALS_FREQ=quarterly

# Number of historical quarters to store from financials-reported (default 8 = 2 years).
# Enables 8-quarter margin trend analysis in data-analyzer/fundamental-analysis.
FUNDAMENTAL_FINANCIALS_LIMIT=8

# Also fetch annual (10-K) reports alongside quarterly in a separate API call.
FUNDAMENTAL_ENABLE_ANNUAL_FINANCIALS=true
# Number of annual (10-K) reports to store (default 5 = 5 years of history).
FUNDAMENTAL_ANNUAL_FINANCIALS_LIMIT=5

# Feature toggles.
FUNDAMENTAL_ENABLE_METRICS=true
FUNDAMENTAL_ENABLE_FINANCIALS=true
FUNDAMENTAL_ENABLE_EARNINGS=true
# Requires ALPHA_VANTAGE_API_KEY to be set; silently skips if key is missing.
FUNDAMENTAL_ENABLE_OVERVIEW=true
# Analyst consensus recommendation trend (Finnhub free tier, no extra key needed).
FUNDAMENTAL_ENABLE_RECOMMENDATION=true
DATA_FUNDAMENTAL_RECOMMENDATION_POLL_INTERVAL=24h

# Qualitative data ingestion (SEC Form 4 insider transactions + news sentiment)
# Insider transactions: Finnhub /stock/insider-transactions (free tier)
FUNDAMENTAL_ENABLE_INSIDER_TRANSACTIONS=true
DATA_FUNDAMENTAL_INSIDER_POLL_INTERVAL=24h
# News sentiment: Alpha Vantage NEWS_SENTIMENT (free tier, costs 1 call/symbol/day)
FUNDAMENTAL_ENABLE_NEWS_SENTIMENT=true
DATA_FUNDAMENTAL_NEWS_SENTIMENT_POLL_INTERVAL=24h
# Institutional ownership: Finnhub /stock/investor-ownership (free tier, quarterly)
FUNDAMENTAL_ENABLE_INSTITUTIONAL_OWNERSHIP=true
DATA_FUNDAMENTAL_INSTITUTIONAL_POLL_INTERVAL=168h
FUNDAMENTAL_INSTITUTIONAL_OWNERSHIP_LIMIT=25

# Qualitative analysis thresholds
QUAL_INSIDER_CLUSTER_WINDOW_DAYS=90
QUAL_INSIDER_CLUSTER_MIN_BUYERS=3
QUAL_MOAT_STABILITY_QUARTERS=8
QUAL_MOAT_STABLE_STD_PP=5
QUAL_SENTIMENT_POSITIVE_THRESHOLD=0.15
QUAL_SENTIMENT_NEGATIVE_THRESHOLD=-0.15
QUAL_RD_HEALTHY_PCT=10
QUAL_RD_MODERATE_PCT=3

# --- data-onchain ---
GLASSNODE_API_KEY=
ETHERSCAN_API_KEY=

# --- data-sentiment (LunarCrush uses FINNHUB_SYMBOLS_FOR_NEWS list for coin symbols) ---
LUNARCRUSH_API_KEY=
FINNHUB_SYMBOLS_FOR_NEWS=BTC,ETH,AAPL

# --- data-technical ---
# Symbols to analyse (defaults to ALPACA_DATA_SYMBOLS / BINANCE_SYMBOLS if unset).
TECHNICAL_EQUITY_SYMBOLS=AAPL,MSFT,SPY
TECHNICAL_CRYPTO_SYMBOLS=BTCUSDT,ETHUSDT

# Bar timeframes to ingest and compute (comma-separated).
# Equity uses Alpaca format: 1Min, 5Min, 15Min, 1Hour, 1Day, 1Week, 1Month
# Crypto uses Binance format: 1m, 5m, 15m, 1h, 4h, 1d, 1w
TECHNICAL_EQUITY_INTERVALS=1Day
TECHNICAL_CRYPTO_INTERVALS=1d

# How many historical bars to ensure are stored on startup (backfill target).
# 500 daily bars ≈ 2 years of history, sufficient for 200-period SMA/EMA.
TECHNICAL_BACKFILL_BARS=500

# How many bars to read from the DB for each computation run.
TECHNICAL_COMPUTE_LOOKBACK=500

# How often to fetch the latest bars and recompute all indicators (Go duration).
DATA_TECHNICAL_POLL_INTERVAL=6h

# ── data-analyzer ─────────────────────────────────────────────────────────────
# Seconds to wait on container startup before running the first computation.
# Ensures data-technical has completed its initial OHLCV backfill.
# Reduce to 0 for local dev (run against a pre-populated DB).
ANALYZER_STARTUP_DELAY_SECS=60

# How often technical-analysis re-reads OHLCV and recomputes all indicators.
# Defaults to DATA_TECHNICAL_POLL_INTERVAL (6h). Use a shorter value for dev.
# DATA_TECHNICAL_POLL_INTERVAL is reused intentionally; set separately if needed.

# How often fundamental-analysis re-derives composite scores.
DATA_FUNDAMENTAL_ANALYSIS_POLL_INTERVAL=24h

# Minimum number of raw metrics required before scoring a symbol (skip if below).
FUNDAMENTAL_ANALYSIS_MIN_METRICS=5
# Startup delay before the first scoring run — gives data-fundamental time to
# complete its first ingestion pass. Set to 0 if the DB is already populated.
FUNDAMENTAL_STARTUP_DELAY_SECS=30

# ── Fundamental analysis scoring thresholds ───────────────────────────────────
# All thresholds are in percentage points unless noted. Adjust per sector or
# market regime without recompiling. These control the scoring algorithm in
# services/data-analyzer/cmd/fundamental-analysis/main.go.

# EPS YoY growth: >strong = "strong", <weak = "weak", else "neutral"
FUNDAMENTAL_EPS_GROWTH_STRONG=15
FUNDAMENTAL_EPS_GROWTH_WEAK=5

# Revenue YoY growth: >strong = "strong", <weak = "weak"
FUNDAMENTAL_REV_GROWTH_STRONG=10
FUNDAMENTAL_REV_GROWTH_WEAK=2

# P/E vs own 5-year mean: deviation below this% = "cheap", above = "expensive"
FUNDAMENTAL_PE_5Y_CHEAP_PCT=15
FUNDAMENTAL_PE_5Y_EXPENSIVE_PCT=15

# P/E absolute fallback (when no 5-year history is available)
FUNDAMENTAL_PE_ABS_VALUE=15
FUNDAMENTAL_PE_ABS_GROWTH=25

# FCF yield (%): >=attractive = "attractive", >=fair = "fair", else "avoid"
FUNDAMENTAL_FCF_YIELD_ATTRACTIVE=5
FUNDAMENTAL_FCF_YIELD_FAIR=2

# FCF / EPS divergence detection — flags suspect earnings quality
FUNDAMENTAL_FCF_DIV_EPS_GROWTH=10
FUNDAMENTAL_FCF_DIV_YIELD_LOW=2
FUNDAMENTAL_FCF_DIV_YIELD_HIGH=5

# Gross margin (%): >=moat = "strong_moat", >=avg = "average", else "pressure"
FUNDAMENTAL_GROSS_MARGIN_MOAT=40
FUNDAMENTAL_GROSS_MARGIN_AVG=20

# Net margin (%): >=strong = "strong", >=avg = "average", else "pressure"
FUNDAMENTAL_NET_MARGIN_STRONG=15
FUNDAMENTAL_NET_MARGIN_AVG=5

# Forward P/E vs trailing P/E: within ±flat% = "flat"
FUNDAMENTAL_PE_COMPRESSION_FLAT=5

# PEG ratio: <undervalued = "undervalued_growth", <fair = "fairly_valued_growth"
FUNDAMENTAL_PEG_UNDERVALUED=1
FUNDAMENTAL_PEG_FAIR=2

# Earnings surprise: avg >= beat% = "beat", avg <= -miss% = "miss", else "inline"
FUNDAMENTAL_SURPRISE_BEAT_PCT=2
FUNDAMENTAL_SURPRISE_MISS_PCT=2
# Max number of recent quarters to include in the rolling average
FUNDAMENTAL_SURPRISE_QUARTERS=4

# Composite score boundaries: >=strong = "strong", <=-weak = "weak"
FUNDAMENTAL_COMPOSITE_STRONG=0.5
FUNDAMENTAL_COMPOSITE_WEAK=0.5

# Margin trend (8-quarter window): change within ±stable pp = "stable"
FUNDAMENTAL_MARGIN_TREND_STABLE_PP=2
FUNDAMENTAL_MARGIN_TREND_QUARTERS=8

# Moving average periods (comma-separated integers).
TECHNICAL_SMA_PERIODS=20,50,100,200
TECHNICAL_EMA_PERIODS=9,21,50,200

# RSI period.
TECHNICAL_RSI_PERIOD=14

# Volume SMA period (used for vol_sma_N and rel_vol indicators).
TECHNICAL_VOL_SMA_PERIOD=20

# Support & Resistance: bars on each side to qualify a swing point.
TECHNICAL_SR_SWING_STRENGTH=5
# Max support and resistance levels to store.
TECHNICAL_SR_LEVELS=3
# Price proximity tolerance (%) for clustering nearby levels into one.
TECHNICAL_SR_CLUSTER_PCT=0.5

# Trend analysis: bars used for slope and HH/HL structure check.
TECHNICAL_TREND_LOOKBACK=60

# Feature toggles (set to false to disable a group entirely).
TECHNICAL_ENABLE_MA=true
TECHNICAL_ENABLE_RSI=true
TECHNICAL_ENABLE_VOLUME=true
TECHNICAL_ENABLE_SR=true
TECHNICAL_ENABLE_TREND=true
TECHNICAL_ENABLE_CANDLES=true
# Number of most-recent bars to scan for candlestick patterns (3 = doji, engulfing, etc).
TECHNICAL_CANDLE_WINDOW=3

# Tier 2 — momentum, volatility, structure (each row in technical_indicators is per symbol × interval).
TECHNICAL_ENABLE_MACD=true
TECHNICAL_MACD_FAST=12
TECHNICAL_MACD_SLOW=26
TECHNICAL_MACD_SIGNAL=9

TECHNICAL_ENABLE_OBV=true

TECHNICAL_ENABLE_BOLLINGER=true
TECHNICAL_BB_PERIOD=20
TECHNICAL_BB_STD=2

TECHNICAL_ENABLE_FIB=true
# 0 = reuse TECHNICAL_SR_SWING_STRENGTH for Fib pivots.
TECHNICAL_FIB_SWING_STRENGTH=0
TECHNICAL_FIB_EXTENSIONS=true

TECHNICAL_ENABLE_RSI_DIVERGENCE=true
# 0 = reuse TECHNICAL_SR_SWING_STRENGTH for RSI swing pivots.
TECHNICAL_RSI_DIV_SWING_STRENGTH=0

# Histogram proxy: each bar's volume → one price bin (typical price or close); not tape/L2.
TECHNICAL_ENABLE_VOL_PROFILE_PROXY=true
TECHNICAL_VOL_PROFILE_BINS=48
TECHNICAL_VOL_PROFILE_TYPICAL=true
# Value area: expand bins from POC until this fraction of histogram volume is captured (e.g. 0.70 = 70%).
TECHNICAL_VOL_PROFILE_VALUE_AREA_PCT=0.70

# RSI hidden (continuation) divergence: min bars between the two pivots; optional trend gate (AnalyzeTrend on window ending at 2nd pivot).
TECHNICAL_ENABLE_RSI_HIDDEN=true
TECHNICAL_RSI_HIDDEN_MIN_PIVOT_SEP=3
TECHNICAL_RSI_HIDDEN_REQUIRE_TREND=true

# Tier 3 — secondary indicators (same DB grain: per symbol × interval).
TECHNICAL_ENABLE_STOCHASTIC=true
TECHNICAL_STOCH_K=14
TECHNICAL_STOCH_D_SMOOTH=3
TECHNICAL_STOCH_D_SIGNAL=3

TECHNICAL_ENABLE_ATR=true
TECHNICAL_ATR_PERIOD=14

TECHNICAL_ENABLE_ICHIMOKU=true
TECHNICAL_ICHIMOKU_TENKAN=9
TECHNICAL_ICHIMOKU_KIJUN=26
TECHNICAL_ICHIMOKU_SPAN_B=52
# 0 = use Kijun length as Senkou displacement (standard 26).
TECHNICAL_ICHIMOKU_DISPLACE=0

TECHNICAL_ENABLE_AD_LINE=true

TECHNICAL_ENABLE_ADX=true
TECHNICAL_ADX_PERIOD=14

# Classic / Camarilla / Woodie from prior bar H/L/C (bars[len-2]).
TECHNICAL_ENABLE_PIVOTS=true

TECHNICAL_ENABLE_WILLIAMS_R=true
TECHNICAL_WILLIAMS_R_PERIOD=14

# VWAP: rolling window over last N bars, or session = all bars on last bar's UTC calendar day (useful on intraday bars).
TECHNICAL_ENABLE_VWAP=true
TECHNICAL_VWAP_MODE=rolling
TECHNICAL_VWAP_ROLLING_N=20
TECHNICAL_VWAP_USE_TYPICAL=true

# MA ribbon: periods ascending short→long; golden/death cross on SMA pair (default 50/200).
TECHNICAL_ENABLE_MA_RIBBON=true
TECHNICAL_RIBBON_PERIODS=10,20,50,200
TECHNICAL_MA_CROSS_FAST=50
TECHNICAL_MA_CROSS_SLOW=200

# Heuristic double top/bottom candidates from last two swings (not full pattern recognition).
TECHNICAL_ENABLE_CHART_PATTERNS=true
TECHNICAL_CHART_PATTERN_CLUSTER_PCT=0.5

# --- Channels / flow / oscillators (OHLCV) ---
TECHNICAL_ENABLE_CMF=true
TECHNICAL_CMF_PERIOD=21

TECHNICAL_ENABLE_KELTNER=true
TECHNICAL_KELTNER_EMA=20
TECHNICAL_KELTNER_ATR=10
TECHNICAL_KELTNER_MULT=2

TECHNICAL_ENABLE_DONCHIAN=true
TECHNICAL_DONCHIAN_PERIOD=20

# OLS trendlines through last N swing highs / lows; break vs prior close.
TECHNICAL_ENABLE_TRENDLINE_BREAK=true
TECHNICAL_TRENDLINE_PIVOTS=3

TECHNICAL_ENABLE_CCI=true
TECHNICAL_CCI_PERIOD=20

TECHNICAL_ENABLE_ROC=true
TECHNICAL_ROC_PERIOD=12

TECHNICAL_ENABLE_PARABOLIC_SAR=true
TECHNICAL_PARABOLIC_STEP=0.02
TECHNICAL_PARABOLIC_MAX_AF=0.2

TECHNICAL_ENABLE_MFI=true
TECHNICAL_MFI_PERIOD=14

# --- Structure / discretionary context ---
TECHNICAL_ENABLE_MARKET_STRUCTURE=true
TECHNICAL_ENABLE_ELLIOTT_HINT=true
TECHNICAL_ENABLE_GANN_HINT=true
TECHNICAL_GANN_LOOKBACK=60

# Documents that OI is not in OHLCV (stores payload only when true).
TECHNICAL_ENABLE_OPEN_INTEREST_INFO=false

# Relative strength vs a second symbol in DB (same interval; timestamp-aligned closes).
TECHNICAL_ENABLE_RS_BENCHMARK=false
TECHNICAL_RS_BENCHMARK_EQUITY=SPY
TECHNICAL_RS_BENCHMARK_CRYPTO=BTCUSDT
TECHNICAL_RS_MIN_ALIGNED_BARS=30

# Multi-timeframe trend confluence: compare primary interval trend to these secondary intervals (same symbol).
TECHNICAL_ENABLE_MTF_CONFLUENCE=false
TECHNICAL_MTF_EQUITY_INTERVALS=1Week
TECHNICAL_MTF_CRYPTO_INTERVALS=1w

# ── SMC — Fair Value Gaps (Panel 6) ─────────────────────────────────────────
# 3-candle imbalance zones where price may return to "fill". Pure OHLCV.
TECHNICAL_ENABLE_FVG=true
TECHNICAL_FVG_MIN_GAP_PCT=0.1        # minimum gap width as % of mid-price (filters noise)
TECHNICAL_FVG_LOOKBACK=50            # bars to scan (within TECHNICAL_COMPUTE_LOOKBACK)

# ── SMC — Order Blocks (Panel 6) ─────────────────────────────────────────────
# Last opposing candle before a strong impulse move. Price often returns to test these zones.
TECHNICAL_ENABLE_ORDER_BLOCKS=true
TECHNICAL_OB_SWING_STRENGTH=3        # pivot strength for impulse detection
TECHNICAL_OB_IMPULSE_MIN_PCT=1.5     # minimum % move to qualify as an impulse
TECHNICAL_OB_LOOKBACK=100

# ── SMC — Liquidity Sweeps (Panel 6) ─────────────────────────────────────────
# Price wicks through a prior swing high/low (stop-hunt) then closes back — classic institutional move.
TECHNICAL_ENABLE_LIQUIDITY_SWEEP=true
TECHNICAL_LIQUIDITY_SWING_STRENGTH=3
TECHNICAL_LIQUIDITY_LOOKBACK=50

# ── Bollinger Squeeze (Panel 5) ───────────────────────────────────────────────
# BB inside Keltner → low-volatility coil → watch for expansion breakout.
# Requires TECHNICAL_ENABLE_BOLLINGER=true and TECHNICAL_ENABLE_KELTNER=true.
TECHNICAL_ENABLE_BB_SQUEEZE=true

# ── VIX Regime (Panel 5) ──────────────────────────────────────────────────────
# Reads latest VIXCLS from macro_fred table (populated by data-macro/FRED worker).
# Ensure FRED_SERIES_IDS includes VIXCLS in your data-ingestion config.
TECHNICAL_ENABLE_VIX_REGIME=true
TECHNICAL_VIX_FEAR_THRESHOLD=35       # VIX above this → extreme_fear
TECHNICAL_VIX_ELEVATED_THRESHOLD=20   # VIX above this → elevated
TECHNICAL_VIX_COMPLACENCY_THRESHOLD=12 # VIX below this → complacency

# ── Weekly / Monthly Pivot Points (Panel 1) ───────────────────────────────────
# Computes Classic, Camarilla, and Woodie's pivots from the prior weekly/monthly bar.
# Requires the corresponding interval to be ingested (data-equity/data-crypto).
TECHNICAL_ENABLE_WEEKLY_PIVOTS=true
TECHNICAL_ENABLE_MONTHLY_PIVOTS=false
TECHNICAL_WEEKLY_PIVOT_EQUITY_INTERVAL=1Week
TECHNICAL_WEEKLY_PIVOT_CRYPTO_INTERVAL=1w
TECHNICAL_MONTHLY_PIVOT_EQUITY_INTERVAL=1Month
TECHNICAL_MONTHLY_PIVOT_CRYPTO_INTERVAL=1M
# How many weekly / monthly bars to fetch when computing multi-TF pivot levels.
TECHNICAL_WEEKLY_PIVOT_LOOKBACK=10
TECHNICAL_MONTHLY_PIVOT_LOOKBACK=5

# ── Head & Shoulders Pattern (Panel 1) ───────────────────────────────────────
# Detects both H&S (bearish reversal) and Inverse H&S (bullish reversal) using swing pivots.
TECHNICAL_ENABLE_HS_PATTERN=true
TECHNICAL_HS_SWING_STRENGTH=5         # pivot strength — higher = fewer but more reliable pivots
TECHNICAL_HS_TOLERANCE_PCT=15.0       # max % difference between left and right shoulder heights
TECHNICAL_HS_LOOKBACK=100

# ── Triangle Patterns (Panel 1) ───────────────────────────────────────────────
# Ascending / Descending / Symmetrical triangles from linear regression of swing pivots.
TECHNICAL_ENABLE_TRIANGLE=true
TECHNICAL_TRIANGLE_SWING_STRENGTH=3
TECHNICAL_TRIANGLE_MIN_PIVOTS=3       # minimum swing highs AND lows on each trendline
TECHNICAL_TRIANGLE_FLAT_THRESHOLD_PCT=0.05  # slope (%/bar) below which a line is "flat"
TECHNICAL_TRIANGLE_LOOKBACK=100

# ── Flag / Pennant (Panel 1) ──────────────────────────────────────────────────
# Strong impulse ("pole") followed by a contained consolidation channel.
TECHNICAL_ENABLE_FLAG=true
TECHNICAL_FLAG_POLE_PCT=5.0           # minimum % move for the pole
TECHNICAL_FLAG_MAX_RETRACEMENT_PCT=50.0  # maximum % retracement within the flag body
TECHNICAL_FLAG_POLE_LEN=5             # bars for the pole phase
TECHNICAL_FLAG_LEN=10                 # bars for the consolidation phase

# ── Tier 3 FA thresholds (fundamental-analysis service) ──────────────────────
# Rank 13 — Share Count Trend
FUNDAMENTAL_SHARE_DECLINE_BUYBACK=2
FUNDAMENTAL_SHARE_GROWTH_DILUTION=3
FUNDAMENTAL_SHARE_TREND_YEARS=2
# Rank 14 — DCF Intrinsic Value (simplified)
FUNDAMENTAL_DCF_WACC_PCT=10
FUNDAMENTAL_DCF_TERMINAL_GROWTH_PCT=3
FUNDAMENTAL_DCF_GROWTH_YEARS=5
FUNDAMENTAL_DCF_MAX_GROWTH_PCT=20
FUNDAMENTAL_DCF_SAFETY_MARGIN_PCT=70
FUNDAMENTAL_DCF_OVERVALUED_PCT=110
# Rank 15 — Interest Coverage
FUNDAMENTAL_INTEREST_COVERAGE_SAFE=5
FUNDAMENTAL_INTEREST_COVERAGE_ADEQUATE=2
# Rank 17 — Analyst Target Price
FUNDAMENTAL_ANALYST_UPSIDE_BULLISH=15
FUNDAMENTAL_ANALYST_DOWNSIDE_BEARISH=-5
FUNDAMENTAL_EQUITY_INTERVAL=1Day
# Rank 18 — Goodwill & Intangibles
FUNDAMENTAL_GOODWILL_LOW_PCT=20
FUNDAMENTAL_GOODWILL_HIGH_PCT=40
# Rank 19 — P/S Ratio
FUNDAMENTAL_PS_VALUE=5
FUNDAMENTAL_PS_FAIR=10
FUNDAMENTAL_PS_SPECULATIVE=15
# Tier 2 — ROIC: 5-year average Return on Invested Capital (Finnhub roic5Y)
FUNDAMENTAL_ROIC_EXCELLENT=15
FUNDAMENTAL_ROIC_ADEQUATE=8
# Tier 3 — FCF Conversion Rate (FCF / Net Income)
FUNDAMENTAL_FCF_CONVERSION_HIGH=1.0
FUNDAMENTAL_FCF_CONVERSION_LOW=0.7
# Tier 3 — Analyst Recommendation Trend (month-over-month delta in net analyst buy score)
FUNDAMENTAL_ANALYST_REC_UPGRADE_DELTA=5
FUNDAMENTAL_ANALYST_REC_DOWNGRADE_DELTA=-5

# ── Correlation Analysis Thresholds ───────────────────────────────────────────
# Cross-metric divergence signals — see bot.md Correlations section for full details.
# Minimum conditions (out of 5) for Bullish Convergence master signal. Range: 2–5.
CORR_BULLISH_CONVERGENCE_MIN_CONDITIONS=3
# Minimum conditions (out of 4) for Value Trap master signal. Range: 2–4.
CORR_VALUE_TRAP_MIN_CONDITIONS=3
# Minimum conditions (out of 4) for Leverage Cycle Warning master signal. Range: 2–4.
CORR_LEVERAGE_CYCLE_MIN_CONDITIONS=3
# Receivables/revenue growth multiplier for Deterioration Warning detection.
# 1.1 = receivables growing 10% faster than revenue triggers the warning.
CORR_RECEIVABLES_GROWTH_MULTIPLIER=1.1

